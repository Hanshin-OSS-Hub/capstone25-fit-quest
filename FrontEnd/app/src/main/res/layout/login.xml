<?xml version="1.0" encoding="utf-8"?>

<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/img_login_back"
        android:scaleType="centerCrop" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#66000000" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <TextView
            android:id="@+id/fit_quest_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="FitQuest"
            android:textSize="60sp"
            android:textStyle="italic"
            android:textColor="@android:color/white"
            android:letterSpacing="0.05"
            android:shadowColor="#80000000"
            android:shadowDx="0"
            android:shadowDy="2"
            android:shadowRadius="6"
            android:fontFamily="@font/poppins_bold"
            android:gravity="center"
            app:autoSizeTextType="uniform"
            app:autoSizeMinTextSize="32sp"
            app:autoSizeMaxTextSize="64sp"
            app:autoSizeStepGranularity="2sp"

            app:layout_constraintWidth_percent="0.8"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintVertical_bias="0.33" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/fit_login"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:minHeight="50dp"
            android:maxHeight="60dp"
            android:layout_marginBottom="8dp"

            android:text="로그인"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            app:autoSizeTextType="uniform"
            app:autoSizeMinTextSize="14sp"
            app:autoSizeMaxTextSize="18sp"

            android:fontFamily="@font/poppins_bold"

            app:backgroundTint="#1565C0"
            app:cornerRadius="12dp"
            app:strokeWidth="2dp"
            app:strokeColor="#0D47A1"
            app:elevation="4dp"

            app:layout_constraintWidth_percent="0.3"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintVertical_bias="0.45" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/fit_SignUp"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:minHeight="50dp"
            android:maxHeight="60dp"
            android:layout_marginTop="8dp"

            android:text="회원가입"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            app:autoSizeTextType="uniform"
            app:autoSizeMinTextSize="12sp"
            app:autoSizeMaxTextSize="15sp"

            android:fontFamily="@font/poppins_bold"

            app:backgroundTint="#1565C0"
            app:cornerRadius="12dp"
            app:strokeWidth="2dp"
            app:strokeColor="#0D47A1"
            app:elevation="4dp"

            app:layout_constraintWidth_percent="0.3"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintVertical_bias="0.52" />

        <ImageButton
            android:id="@+id/kakao_login"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:src="@drawable/img_kakao_login"
            android:scaleType="fitCenter"
            android:adjustViewBounds="true"
            android:background="@android:color/transparent"
            android:contentDescription="카카오 로그인"

            app:layout_constraintWidth_percent="0.5"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintVertical_bias="0.7" />

        <ImageButton
            android:id="@+id/naver_login"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:src="@drawable/img_naver_login"
            android:scaleType="fitCenter"
            android:adjustViewBounds="true"
            android:background="@android:color/transparent"
            android:contentDescription="네이버 로그인"

            app:layout_constraintWidth_percent="0.5"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintVertical_bias="0.8" />

        <ImageButton
            android:id="@+id/google_login"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:src="@drawable/img_google_login"
            android:scaleType="fitCenter"
            android:adjustViewBounds="true"
            android:background="@android:color/transparent"
            android:contentDescription="구글 로그인"

            app:layout_constraintWidth_percent="0.5"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintVertical_bias="0.9" />

        <Button
            android:id="@+id/test"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="홈"

            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.05"
            app:layout_constraintHorizontal_bias="0.5" />

        <Button
            android:id="@+id/test2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="헬스"

            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.15"
            app:layout_constraintHorizontal_bias="0.5" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>